POSTGRES_DB=spbnext_portal
POSTGRES_USER=spbnext
POSTGRES_PASSWORD=change-this-database-password
HTTP_PORT=80

NODE_ENV=production
PORT=4000
APP_URL=https://portal.example.com
JWT_SECRET=change-this-with-a-long-random-secret
JWT_EXPIRES_IN=8h
COOKIE_SECRET=change-this-cookie-secret

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-user
SMTP_PASS=your-password
SMTP_FROM="SPBnext Portal <no-reply@example.com>"
